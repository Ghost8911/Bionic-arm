#include <ESP32Servo.h>

// ── Servo objects ──
Servo shoulder;
Servo elbow;
Servo wrist;
Servo gripper;

// ── GPIO pins ──
#define PIN_SHOULDER 13
#define PIN_ELBOW    12
#define PIN_WRIST    14
#define PIN_GRIPPER  27

// ── Starting angles ──
int angShoulder = 90;
int angElbow    = 90;
int angWrist    = 90;
int angGripper  = 90;  // 90 = open, 30 = closed

// ── Step size per keypress ──
#define STEP 5

// ── Clamp helper ──
int clamp(int val, int minVal, int maxVal) {
  if (val < minVal) return minVal;
  if (val > maxVal) return maxVal;
  return val;
}

void setup() {
  Serial.begin(9600);

  shoulder.attach(PIN_SHOULDER);
  elbow.attach(PIN_ELBOW);
  wrist.attach(PIN_WRIST);
  gripper.attach(PIN_GRIPPER);

  // Move all to center
  shoulder.write(angShoulder);
  elbow.write(angElbow);
  wrist.write(angWrist);
  gripper.write(angGripper);

  Serial.println("Bionic Arm Ready!");
  Serial.println("W/S = Elbow  |  A/D = Shoulder  |  Q/E = Wrist  |  O/C = Gripper  |  SPACE = Center");
}

void loop() {
  if (Serial.available() > 0) {
    char cmd = Serial.read();

    switch (cmd) {

      // ── Shoulder ──
      case 'a': case 'A':
        angShoulder = clamp(angShoulder - STEP, 0, 180);
        shoulder.write(angShoulder);
        Serial.print("Shoulder: "); Serial.println(angShoulder);
        break;

      case 'd': case 'D':
        angShoulder = clamp(angShoulder + STEP, 0, 180);
        shoulder.write(angShoulder);
        Serial.print("Shoulder: "); Serial.println(angShoulder);
        break;

      // ── Elbow ──
      case 'w': case 'W':
        angElbow = clamp(angElbow + STEP, 0, 180);
        elbow.write(angElbow);
        Serial.print("Elbow: "); Serial.println(angElbow);
        break;

      case 's': case 'S':
        angElbow = clamp(angElbow - STEP, 0, 180);
        elbow.write(angElbow);
        Serial.print("Elbow: "); Serial.println(angElbow);
        break;

      // ── Wrist ──
      case 'q': case 'Q':
        angWrist = clamp(angWrist - STEP, 0, 180);
        wrist.write(angWrist);
        Serial.print("Wrist: "); Serial.println(angWrist);
        break;

      case 'e': case 'E':
        angWrist = clamp(angWrist + STEP, 0, 180);
        wrist.write(angWrist);
        Serial.print("Wrist: "); Serial.println(angWrist);
        break;

      // ── Gripper ──
      case 'o': case 'O':
        angGripper = clamp(angGripper + STEP, 30, 90);
        gripper.write(angGripper);
        Serial.print("Gripper: "); Serial.println(angGripper);
        break;

      case 'c': case 'C':
        angGripper = clamp(angGripper - STEP, 30, 90);
        gripper.write(angGripper);
        Serial.print("Gripper: "); Serial.println(angGripper);
        break;

      // ── Center all ──
      case ' ':
        angShoulder = 90;
        angElbow    = 90;
        angWrist    = 90;
        angGripper  = 90;
        shoulder.write(90);
        elbow.write(90);
        wrist.write(90);
        gripper.write(90);
        Serial.println("All servos centered!");
        break;
    }
  }
}
